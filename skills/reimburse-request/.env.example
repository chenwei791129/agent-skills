# Reimburse.digital organisation identifier (required).
# This is the company / tenant code the login page asks for on the
# "Enter Your Organisation ID" screen. Single-quote it to be safe.
ORGANISATION_ID='your-org-id'

# Login account for your organisation's SSO (required).
# After the organisation id, reimburse.digital redirects to your organisation's
# own SSO / identity provider — these are the credentials you use there. If the
# account carries a domain backslash (DOMAIN\account), wrap it in SINGLE quotes,
# otherwise `source .env` eats the `\` as an escape character and login fails.
REIMBURSE_USERNAME='your.account'

# Login password (required). Single-quote it too so the shell doesn't interpret
# any special characters.
REIMBURSE_PASSWORD='your-password'

# Optional: override the app entry URL. Defaults to https://app.reimburse.digital/
# Uncomment and change only if your tenant uses a different host.
# REIMBURSE_URL='https://app.reimburse.digital/'

# Lookup order for credentials: the .env in the working directory > the path
# passed via --env. Copy this file to .env and fill it in; never commit the real
# .env to version control.
