# SAP SuccessFactors login account (required).
# The account usually carries a domain backslash (DOMAIN\account); wrap it in
# SINGLE quotes, otherwise `source .env` eats the `\` as an escape character and
# login fails.
SAP_USERNAME='DOMAIN\your.account'

# Login password (required). Single-quote it too so the shell doesn't interpret
# any special characters.
SAP_PASSWORD='your-password'

# Your company's SuccessFactors home URL (required).
# The host (SAP datacenter, e.g. hcm-apXX...) and the bplte_company company code
# vary by organization; after a successful login the browser should land here.
SAP_URL='https://<your-sf-host>/sf/home?bplte_company=<your-company>'

# Lookup order for credentials: the .env in the working directory > the path
# passed via --env. Copy this file to .env and fill it in; never commit the real
# .env to version control.
